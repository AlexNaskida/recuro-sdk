{
  "name": "@recuro/sdk",
  "version": "0.1.2",
  "description": "Non-custodial recurring USDC subscriptions on Solana",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "type-check": "tsc --noEmit",
    "lint": "eslint src --ext .ts,.tsx --max-warnings 0",
    "test": "vitest run"
  },
  "keywords": [
    "solana",
    "subscription",
    "usdc",
    "anchor",
    "defi",
    "payments",
    "recurring",
    "recuro"
  ],
  "license": "MIT",
  "homepage": "https://github.com/AlexNaskida/recuro-sdk",
  "repository": {
    "type": "git",
    "url": "https://github.com/AlexNaskida/recuro-sdk.git"
  },
  "bugs": {
    "url": "https://github.com/AlexNaskida/recuro-sdk/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "@coral-xyz/anchor": "^0.32.0",
    "@solana/spl-token": "^0.4.14",
    "@solana/web3.js": "^1.87.0",
    "react": "^18.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@coral-xyz/anchor": "^0.32.0",
    "@solana/spl-token": "^0.4.14",
    "@solana/web3.js": "^1.87.0",
    "@types/bn.js": "^5.2.0",
    "@types/node": "^20.0.0",
    "@types/react": "^18.2.0",
    "react": "^18.2.0",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0",
    "vitest": "^1.2.0"
  },
  "dependencies": {
    "@coral-xyz/anchor": "^0.32.0",
    "bn.js": "^5.2.1"
  }
}