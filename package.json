{
  "name": "@recuro/sdk",
  "version": "0.1.0",
  "description": "Non-custodial recurring USDC subscriptions on Solana",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "type-check": "tsc --noEmit",
    "test": "vitest run"
  },
  "keywords": [
    "solana",
    "subscription",
    "usdc",
    "anchor",
    "defi",
    "payments",
    "recurring",
    "recuro"
  ],
  "license": "MIT",
  "homepage": "https://github.com/YOUR_USERNAME/recuro-sdk",
  "repository": {
    "type": "git",
    "url": "https://github.com/YOUR_USERNAME/recuro-sdk.git"
  },
  "bugs": {
    "url": "https://github.com/YOUR_USERNAME/recuro-sdk/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "@coral-xyz/anchor": "^0.32.0",
    "@solana/spl-token": "^0.3.11",
    "@solana/web3.js": "^1.87.0"
  },
  "devDependencies": {
    "@coral-xyz/anchor": "^0.32.0",
    "@solana/spl-token": "^0.3.11",
    "@solana/web3.js": "^1.87.0",
    "@types/bn.js": "^5.2.0",
    "@types/node": "^20.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0",
    "vitest": "^1.2.0"
  },
  "dependencies": {
    "@coral-xyz/anchor": "^0.32.0",
    "bn.js": "^5.2.1"
  },
  "packageManager": "yarn@1.22.22+sha512.a6b2f7906b721bba3d67d4aff083df04dad64c399707841b7acf00f6b133b7ac24255f2652fa22ae3534329dc6180534e98d17432037ff6fd140556e2bb3137e"
}
